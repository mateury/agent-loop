# === Required ===

# Telegram Bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (get from @userinfobot)
TELEGRAM_USER_ID=

# === Optional ===

# Comma-separated group chat IDs (bot will respond in these groups)
# TELEGRAM_GROUP_IDS=

# Path to Claude Code CLI binary (default: auto-detect)
# CLAUDE_PATH=claude

# Max seconds per Claude invocation (default: 600)
# CLAUDE_TIMEOUT=600
